+/* Task 19: FFI wrapper for the combined keygen+encode pipeline.
+ * Delegates to hawk_keygen (the public API from hawk.h) which runs
+ * Hawk_keygen in a retry loop until encode_public succeeds, then calls
+ * encode_private. Returns 1 on success (hawk_keygen convention). */
+/* Forward-declare hawk_keygen from hawk.h (ng_hawk.c doesn't include hawk.h).
+ * hawk_rng is typedef void(*)(void*,void*,size_t); inline it here to avoid
+ * pulling in hawk.h. */
+extern int hawk_keygen(unsigned logn, void *priv, void *pub,
+    void (*rng)(void *, void *, size_t), void *rng_context,
+    void *tmp, size_t tmp_len);
+int test_hawk_keygen_encoded(
+    const uint8_t *rng_bytes, size_t rng_len,
+    uint8_t *sk_out,
+    uint8_t *pk_out,
+    void *tmp, size_t tmp_len)
+{
+    struct test_hawk_keygen_rng_ctx rngctx = { rng_bytes, 0, rng_len };
+    return hawk_keygen(9, sk_out, pk_out,
+        test_hawk_keygen_rng_cb, &rngctx,
+        tmp, tmp_len);
+}
