+/* 15.23: FFI wrapper for make_q001. Takes int8 (f, g, F, G) plus limits,
+ * writes q00 (int16[n]), q01 (int16[n]), q11 (int32[n]) separately.
+ * After make_q001 succeeds, tmp layout is:
+ *   tmp[0..n/2]   (as u32) = q00 (n int16 packed 2 per u32)
+ *   tmp[n/2..n]   (as u32) = q01 (n int16 packed 2 per u32)
+ *   tmp[n..2n]    (as u32) = q11 (n int32, one per u32)
+ * We use byte-offset arithmetic to extract each field. */
+#ifdef HAWK_DEBUG_TRACE
+int test_make_q001(
+    unsigned logn,
+    int lim00, int lim01, int32_t lim11,
+    const int8_t *f, const int8_t *g,
+    const int8_t *F, const int8_t *G,
+    int16_t *q00_out, int16_t *q01_out, int32_t *q11_out,
+    uint32_t *tmp)
+{
+    int r = make_q001(logn, lim00, lim01, lim11, f, g, F, G, tmp);
+    if (r) {
+        size_t n = (size_t)1 << logn;
+        /* q00: first n int16 starting at tmp byte offset 0. */
+        memcpy(q00_out, (const uint8_t *)tmp, n * sizeof(int16_t));
+        /* q01: next n int16 starting at byte offset n*sizeof(int16_t). */
+        memcpy(q01_out, (const uint8_t *)tmp + n * sizeof(int16_t),
+               n * sizeof(int16_t));
+        /* q11: at tmp[n] (u32 offset n = byte offset n*4). */
+        memcpy(q11_out, tmp + n, n * sizeof(int32_t));
+    }
+    return r;
+}
+
