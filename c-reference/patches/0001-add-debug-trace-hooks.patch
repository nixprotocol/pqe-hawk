+                  uint32_t ig, uint32_t p, uint32_t p0i) {
+    uint32_t buf[512];
+    uint32_t igm[512];
+    memcpy(buf, a_in, sizeof buf);
+    mp_mkigm(9, igm, ig, p, p0i);
+    mp_iNTT(9, buf, igm, p, p0i);
+    memcpy(b_out, buf, sizeof buf);
