+#ifdef HAWK_DEBUG_TRACE
+int test_solve_ntru_deepest(
+    const void *prof, unsigned logn_top,
+    const int8_t *f, const int8_t *g,
+    uint32_t *tmp)
+{
+    return solve_NTRU_deepest((const ntru_profile *)prof, logn_top, f, g, tmp);
+}
+
+/* 15.19d: FFI wrapper for solve_NTRU_intermediate at a chosen depth.
+ * This wrapper runs solve_NTRU_deepest first, then solve_NTRU_intermediate
+ * at the given depth (one call). The caller is responsible for supplying
+ * a tmp buffer large enough for the pipeline. */
+int test_solve_ntru_intermediate_after_deepest(
+    const void *prof,
+    unsigned logn_top,
+    const int8_t *f, const int8_t *g,
+    unsigned depth,
+    uint32_t *tmp)
+{
+    int r = solve_NTRU_deepest((const ntru_profile *)prof, logn_top, f, g, tmp);
+    if (r != SOLVE_OK) {
+        return r;
+    }
+    return solve_NTRU_intermediate((const ntru_profile *)prof, logn_top, f, g, depth, tmp);
+}
