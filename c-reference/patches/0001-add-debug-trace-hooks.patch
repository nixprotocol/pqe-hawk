+/* Forward NTT. Takes coefficients a[512] in [0, p), returns eval-form in b[512].
+ * Caller supplies g, p, p0i so the Rust and C paths agree on prime. */
+void test_mp_ntt(const uint32_t *a_in, uint32_t *b_out,
+                 uint32_t g, uint32_t p, uint32_t p0i) {
+    uint32_t buf[512];
+    uint32_t gm[512];
+    memcpy(buf, a_in, sizeof buf);
+    mp_mkgm(9, gm, g, p, p0i);
+    mp_NTT(9, buf, gm, p, p0i);
+    memcpy(b_out, buf, sizeof buf);
+}
