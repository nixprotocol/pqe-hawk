+/* Test wrapper: byte-exact compute_hm = SHAKE256(msg || hpub) -> 64 bytes.
+ * Mirror of Rust pqe_hawk::hash::compute_hm. */
+void test_compute_hm(const uint8_t *msg, size_t msg_len,
+                     const uint8_t *hpub, size_t hpub_len,
+                     uint8_t out[64]) {
+    shake_context sc;
+    shake_init(&sc, 256);
+    shake_inject(&sc, msg, msg_len);
+    shake_inject(&sc, hpub, hpub_len);
+    shake_flip(&sc);
+    shake_extract(&sc, out, 64);
